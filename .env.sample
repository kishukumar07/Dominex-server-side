# ─── Server ──────────────────────────────────────────────────
PORT=4500

# ─── Database ────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/your_db_name

# ─── Auth ────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here

# ─── Email ───────────────────────────────────────────────────
# For Gmail: enable 2FA and use an App Password (not your real password)
# For Mailtrap: use sandbox credentials below
EMAIL_PROVIDER=gmail
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password_here

# Mailtrap (uncomment to use for dev/testing)
# EMAIL_PROVIDER=sandbox.smtp.mailtrap.io
# EMAIL_PORT=2525
# EMAIL_USER=your_mailtrap_user
# EMAIL_PASSWORD=your_mailtrap_password

# ─── Cloudinary ──────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
UPLOAD_DIR=./public/temp

# ─── AI Provider ─────────────────────────────────────────────
# Options: "gemini" | "openai"
AI_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key
OPENAI_API_KEY=your_openai_api_key

# ─── Bot ─────────────────────────────────────────────────────
BOT_USER_ID=your_bot_user_objectid_from_db

# ─── CORS ────────────────────────────────────────────────────
# Development: * (open)
# Production: https://yourdomain.com
ALLOWED_ORIGIN=http://localhost:3000